{
  "name": "resurface",
  "version": "0.1.0",
  "main": "desktop/main.js",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 7790",
    "build": "next build",
    "start": "next start --port 7790",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "cli": "node cli.mjs",
    "ingest:json": "node scripts/ingest-structured.mjs",
    "ingest:twitter": "node scripts/ingest-twitter-bookmarks.mjs",
    "ingest:birdclaw": "node scripts/import-birdclaw-bookmarks.mjs",
    "desktop:check": "node --check desktop/main.js",
    "desktop:dev": "electron .",
    "desktop:build:dir": "electron-builder --dir --config desktop/electron-builder.yml",
    "desktop:build:mac": "electron-builder --mac --config desktop/electron-builder.yml"
  },
  "dependencies": {
    "next": "15.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "15.3.4",
    "jsdom": "^29.0.1",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
